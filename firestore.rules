
rules_version = '2';

/**
 * AZZURRO COMMUNITY RIDE - FIRESTORE SECURITY RULES
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided ID. */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /** Checks if the document exists and the user is the owner. Used for updates and deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** 
     * Checks if the current user has administrative privileges.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "creator.azzurro@gmail.com" || 
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    /**
     * Checks if a user is currently banned.
     */
    function isBanned(userId) {
      return exists(/databases/$(database)/documents/bans/$(userId)) && 
             (get(/databases/$(database)/documents/bans/$(userId)).data.expiresAt == null || 
              get(/databases/$(database)/documents/bans/$(userId)).data.expiresAt > request.time);
    }

    // --- COLLECTION RULES ---

    match /bans/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    match /drivers/{driverId} {
      allow get, list: if true;
      allow create: if isOwner(driverId) || isAdmin();
      allow update: if (isExistingOwner(driverId)) || isAdmin();
      allow delete: if (isExistingOwner(driverId)) || isAdmin();
    }

    match /drivers/{driverId}/vehicles/{vehicleId} {
      allow get, list: if true;
      allow create: if isOwner(driverId) || isAdmin();
      allow update: if isExistingOwner(driverId) || isAdmin();
      allow delete: if isExistingOwner(driverId) || isAdmin();
    }

    match /rides/{rideId} {
      // Consentiamo la lettura (get e list) a tutti gli utenti loggati (incluso anonimi)
      // per permettere il Lookup tramite codice AZR. Il codice funge da "chiave segreta".
      allow get, list: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (resource.data.passengerId == request.auth.uid || resource.data.driverId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();

      match /chatMessages/{messageId} {
        // Permettiamo la lettura se l'utente è denormalizzato nel messaggio OPPURE se è l'effettivo driver/passeggero della corsa (recuperato dal documento padre)
        allow read, list: if isSignedIn() && (
          isAdmin() || 
          resource.data.ridePassengerId == request.auth.uid || 
          resource.data.rideDriverId == request.auth.uid ||
          get(/databases/$(database)/documents/rides/$(rideId)).data.driverId == request.auth.uid ||
          get(/databases/$(database)/documents/rides/$(rideId)).data.passengerId == request.auth.uid
        );
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      }

      match /history/{versionId} {
        allow read, list, write: if isAdmin();
      }
    }

    match /messages/{messageId} {
      allow read, list: if true;
      allow create: if isSignedIn() && !isBanned(request.auth.uid);
      allow update, delete: if isAdmin() || (resource != null && resource.data.userId == request.auth.uid);
    }

    match /chat_access_logs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    match /support_requests/{requestId} {
      allow get, list: if isAdmin();
      allow create: if true; 
      allow update, delete: if isAdmin();

      match /messages/{messageId} {
        allow read, list: if isAdmin() || (isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/support_requests/$(requestId)).data.userId);
        allow create: if isSignedIn();
      }
    }
  }
}
